PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/dk_clothing
# Local: redis://localhost:6379
# Redis Labs: host:port (password + TLS via vars below)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_ENABLED=true
JWT_SECRET=change-me-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLIENT_URL=http://localhost:3000
RETURN_WINDOW_DAYS=3

# Google Sign-In (OAuth 2.0 Client ID — Web application)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: CLIENT_URL (e.g. http://localhost:3000)
GOOGLE_CLIENT_ID=

# Razorpay (test keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_S3_PREFIX=DK
AWS_CLOUDFRONT_URL=
# S3 bucket CORS must allow PUT from CLIENT_URL for admin image uploads

# SMTP (Gmail example — regular Gmail password will NOT work)
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below (spaces are stripped automatically)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=DK Clothings

# Admin notifications (new orders, return requests). Defaults to SMTP_USER if unset.
ADMIN_EMAIL=

# Store details (shown on tax invoices)
STORE_NAME=DK Clothings
STORE_TAGLINE=Let's Celebrate your elegance
STORE_ADDRESS=
STORE_CITY=
STORE_STATE=
STORE_PINCODE=
STORE_GSTIN=
STORE_PHONE=
STORE_EMAIL=

# App settings
GST_RATE=18
COD_ENABLED=true
DEFAULT_SHIPPING_RATE=99
FREE_SHIPPING_ABOVE=999

# Upload limits (MB) — nginx must allow at least this much: client_max_body_size 15M;
UPLOAD_BANNER_MAX_MB=10
UPLOAD_CATEGORY_MAX_MB=5
UPLOAD_PRODUCT_MAX_MB=8
UPLOAD_JSON_MAX_MB=10
