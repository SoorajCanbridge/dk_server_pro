# Nginx reverse proxy for api.dkclothings.com
# 413 Request Entity Too Large happens when client_max_body_size is too small (default 1m).
# Hero banner uploads can be several MB — set at least 15m.

server {
    listen 443 ssl http2;
    server_name api.dkclothings.com;

    client_max_body_size 15M;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}
